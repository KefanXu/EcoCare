# Deep development: copy to `.env` in this repo root. On Vercel, set these
# in Project Settings → Environment Variables (do not rely on committing .env).

# DeepSeek (default) — uses the OpenAI-compatible endpoint
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# To switch to OpenAI instead, replace the three vars above with:
#   LLM_API_KEY=sk-...
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_MODEL=gpt-4o-mini

PORT=8787
